{% extends 'base.html.twig' %}

{% block title %}Song index{% endblock %}

{% block body %}
    <div class="container">
        <h1>Song index</h1>

        <table class="table">
            <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Artist</th>
                <th>Rewiew</th>
                <th>actions</th>
            </tr>
            </thead>
            <tbody>
            {% for song in songs %}
                <tr>
                    <td>{{ song.id }}</td>
                    <td>{{ song.Name }}</td>
                    <td>{{ song.Artist }}</td>
                    <td>{{ song.Rewiew }}</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_song_show', {'id': song.id}) }}">show</a>
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_song_edit', {'id': song.id}) }}">edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">no records found</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <a class="btn btn-success mt-3" href="{{ path('app_song_new') }}">Create new</a>
    </div>
{% endblock %}
