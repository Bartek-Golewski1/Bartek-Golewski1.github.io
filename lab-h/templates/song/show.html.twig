{% extends 'base.html.twig' %}

{% block title %}Song{% endblock %}

{% block body %}
    <div class="container">
        <h1>Song</h1>

        <table class="table">
            <tbody>
            <tr>
                <th>Id</th>
                <td>{{ song.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ song.Name }}</td>
            </tr>
            <tr>
                <th>Artist</th>
                <td>{{ song.Artist }}</td>
            </tr>
            <tr>
                <th>Rewiew</th>
                <td>{{ song.Rewiew }}</td>
            </tr>
            </tbody>
        </table>

        <a class="btn btn-secondary" href="{{ path('app_song_index') }}">back to list</a>

        <a class="btn btn-primary" href="{{ path('app_song_edit', {'id': song.id}) }}">edit</a>

        {{ include('song/_delete_form.html.twig') }}
    </div>
{% endblock %}
