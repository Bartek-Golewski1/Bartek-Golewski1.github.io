<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <title>Create Song Review</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <h1>Create Song Review</h1>
  <form action="/songs/create" method="POST">
    <p>
      <label>Title</label><br>
      <input type="text" name="title" required style="width: 300px;">
    </p>
    <p>
      <label>Artist</label><br>
      <input type="text" name="artist" required style="width: 300px;">
    </p>
    <p>
      <label>Review</label><br>
      <textarea name="review" rows="6" style="width: 300px;"></textarea>
    </p>
    <button type="submit">Submit</button>
  </form>
  <br>
  <a href="/songs">Back to list</a>
</body>
</html>